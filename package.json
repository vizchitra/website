{
	"name": "vizchitra-website",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "wrangler pages dev .svelte-kit/cloudflare",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"data:fetch": "node scripts/fetch_data.js",
		"prepare": "lefthook install",
		"format": "oxfmt \"**/*.{ts,js,mjs,cjs,json}\" && prettier --write \"**/*.{svelte,md}\"",
		"lint": "pnpm lint:fmt && pnpm lint:fmt:svelte",
		"lint:fmt": "oxfmt --check \"**/*.{ts,js,mjs,cjs,json}\"",
		"lint:fmt:svelte": "prettier --check \"**/*.{svelte,md}\"",
		"lint:code": "oxlint .",
		"audit:css": "node audit/audit.js",
		"audit:tailwind": "node audit/tailwind-audit.js",
		"audit:all": "pnpm audit:css; pnpm audit:tailwind"
	},
	"dependencies": {
		"@handlewithcare/remark-prosemirror": "^0.1.5",
		"fuse.js": "^7.3.0",
		"prosemirror-tables": "^1.8.5",
		"qrcode": "^1.5.4",
		"remark-parse": "^11.0.0",
		"remark-stringify": "^11.0.0",
		"roughjs": "^4.6.6",
		"smol-toml": "^1.6.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260510.1",
		"@content-collections/core": "^0.15.0",
		"@content-collections/markdown": "^0.1.4",
		"@content-collections/vite": "^0.3.0",
		"@neoconfetti/svelte": "^2.2.2",
		"@octokit/rest": "^22.0.1",
		"@resvg/resvg-wasm": "^2.6.2",
		"@rollup/plugin-dsv": "^3.0.5",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.2.4",
		"@types/mdast": "^4.0.4",
		"@types/node": "^25.6.2",
		"@types/papaparse": "^5.5.2",
		"@types/qrcode": "^1.5.6",
		"d3": "^7.9.0",
		"dotenv": "^17.4.2",
		"googleapis": "^171.4.0",
		"gray-matter": "^4.0.3",
		"lefthook": "^2.1.6",
		"marked": "^18.0.3",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.62.0",
		"papaparse": "^5.5.3",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"prosemirror-commands": "^1.7.1",
		"prosemirror-history": "^1.5.0",
		"prosemirror-inputrules": "^1.5.1",
		"prosemirror-keymap": "^1.2.3",
		"prosemirror-markdown": "^1.13.4",
		"prosemirror-model": "^1.25.4",
		"prosemirror-schema-basic": "^1.2.4",
		"prosemirror-schema-list": "^1.5.1",
		"prosemirror-state": "^1.4.4",
		"prosemirror-view": "^1.41.8",
		"rehype-stringify": "^10.0.1",
		"remark-directive": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"remark-rehype": "^11.1.2",
		"satori": "^0.26.0",
		"satori-html": "^0.3.2",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0",
		"vite": "8.0.11",
		"zod": "^4.4.2"
	},
	"engines": {
		"node": ">=22.16.0"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
